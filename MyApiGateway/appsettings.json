{
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "api1": {
            "Address": "http://myapi1:8080/"
          },
          "api2": {
            "Address": "http://myapi2:8080/"
          },
          "api3": {
            "Address": "http://myapi3:8080/"
          }
        }
      }
    }
  }
}